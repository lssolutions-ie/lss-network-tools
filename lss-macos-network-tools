#!/usr/bin/env bash
set -e
set -o pipefail

VERSION="1.0.0"
REPO="korshakov/lss-macos-network-tools"
LOGFILE="/tmp/lss-netinfo-session.log"
DISCOVERY_CACHE="/tmp/lss-discovery-cache"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

IF=""
CURRENT_GATEWAY=""
DHCP_SCAN_OUTPUT=""
DHCP_SCAN_RAN=0

: > "$LOGFILE"

if [[ "${1:-}" == "--version" ]]; then
  echo "LSS macOS Network Tools v${VERSION}"
  exit 0
fi

print_info() {
  echo -e "${BLUE}$*${NC}"
}

print_ok() {
  echo -e "${GREEN}$*${NC}"
}

print_warn() {
  echo -e "${YELLOW}$*${NC}"
}

print_alert() {
  echo -e "${RED}$*${NC}"
}

spinner() {
  local pid=$1
  local delay=0.1
  local spinstr='|/-'

  while ps -p $pid > /dev/null 2>&1; do
    local temp=${spinstr#?}
    printf " [%c]  " "$spinstr"
    spinstr=$temp${spinstr%"$temp"}
    sleep $delay
    printf "\b\b\b\b\b\b"
  done
  printf "    \b\b\b\b"
}

check_dependency() {
  local dep="$1"
  if command -v "$dep" >/dev/null 2>&1; then
    printf "%-18s ${GREEN}PASS${NC}\n" "${dep}:"
    return 0
  fi

  printf "%-18s ${RED}FAIL${NC}\n" "${dep}:"
  return 1
}

install_missing_dependencies() {
  local dep
  for dep in "$@"; do
    if [[ "$dep" == "brew" ]]; then
      print_warn "Homebrew is missing. Installing Homebrew first..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    else
      brew install "$dep"
    fi
  done
}

run_dependency_check() {
  local missing=()
  local dep

  echo
  echo "Dependency Check"
  echo "----------------"

  for dep in brew nmap arp-scan speedtest-cli; do
    if ! check_dependency "$dep"; then
      missing+=("$dep")
    fi
  done

  if [[ ${#missing[@]} -eq 0 ]]; then
    return 0
  fi

  echo
  read -r -p "Install missing dependencies? (y/n) " response
  if [[ "$response" != "y" && "$response" != "Y" ]]; then
    print_alert "Missing dependencies were not installed. Exiting."
    exit 1
  fi

  install_missing_dependencies "${missing[@]}"
}

version_gt() {
  local IFS=.
  local i
  local -a v1=($1) v2=($2)

  for ((i=${#v1[@]}; i<${#v2[@]}; i++)); do
    v1[i]=0
  done
  for ((i=${#v2[@]}; i<${#v1[@]}; i++)); do
    v2[i]=0
  done

  for ((i=0; i<${#v1[@]}; i++)); do
    if ((10#${v1[i]} > 10#${v2[i]})); then
      return 0
    fi
    if ((10#${v1[i]} < 10#${v2[i]})); then
      return 1
    fi
  done

  return 1
}

check_for_updates() {
  local api_url latest_json latest_tag latest_version tarball_url
  api_url="https://api.github.com/repos/${REPO}/releases/latest"

  latest_json="$(curl -fsSL "$api_url" 2>/dev/null || true)"
  [[ -z "$latest_json" ]] && return 0

  latest_tag="$(echo "$latest_json" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)"
  tarball_url="$(echo "$latest_json" | sed -n 's/.*"tarball_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)"
  [[ -z "$latest_tag" || -z "$tarball_url" ]] && return 0

  latest_version="${latest_tag#v}"

  if version_gt "$latest_version" "$VERSION"; then
    echo
    print_warn "Update available: ${latest_tag}"
    print_warn "Current version: v${VERSION}"
    echo
    read -r -p "Install update now? (y/n) " answer

    if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
      install_update "$tarball_url"
    fi
  fi
}

install_update() {
  local tarball_url="$1"
  local tmp_dir archive script_source target_path

  tmp_dir="$(mktemp -d /tmp/lss-update.XXXXXX)"
  archive="$tmp_dir/release.tar.gz"

  print_info "Downloading latest release..."
  curl -fsSL "$tarball_url" -o "$archive"
  tar -xzf "$archive" -C "$tmp_dir"

  script_source="$(find "$tmp_dir" -type f -name 'lss-macos-network-tools' | head -n1)"
  if [[ -z "$script_source" ]]; then
    print_alert "Update failed: script not found in release archive."
    rm -rf "$tmp_dir"
    return 1
  fi

  if [[ "$(basename "$0")" == "lss" && -w "$(command -v lss 2>/dev/null || true)" ]]; then
    target_path="$(command -v lss)"
  elif [[ "$(basename "$0")" == "lss" ]]; then
    target_path="$(command -v lss)"
    sudo cp "$script_source" "$target_path"
    sudo chmod +x "$target_path"
    rm -rf "$tmp_dir"
    print_ok "Update installed successfully. Restarting..."
    exec "$0"
  else
    target_path="$0"
  fi

  cp "$script_source" "$target_path"
  chmod +x "$target_path"
  rm -rf "$tmp_dir"

  print_ok "Update installed successfully. Restarting..."
  exec "$0"
}

get_interfaces() {
  networksetup -listallhardwareports | awk '
    BEGIN { IGNORECASE=1; port="" }
    /^Hardware Port:/ { port=substr($0, index($0, ":") + 2) }
    /^Device:/ {
      device=$2
      if (port ~ /Bluetooth PAN|Thunderbolt Bridge|AWDL|P2P/ || device ~ /awdl|llw|p2p/) {
        next
      }
      print port "|" device
    }
  '
}

select_interface() {
  local choice
  while true; do
    echo
    echo "================================="
    echo " Select Network Interface"
    echo "================================="

    interfaces=()
    while IFS= read -r line; do
      interfaces+=("$line")
    done < <(get_interfaces)

    if [[ ${#interfaces[@]} -eq 0 ]]; then
      print_alert "No usable network interfaces found."
      exit 1
    fi

    local i=1
    local iface port dev
    for iface in "${interfaces[@]}"; do
      port="${iface%%|*}"
      dev="${iface##*|}"
      echo "$i) $port ($dev)"
      ((i++))
    done

    echo
    echo "0) Exit"
    echo
    read -r -p "Select interface: " choice

    if [[ "$choice" == "0" ]]; then
      exit 0
    fi

    IF="${interfaces[$((choice - 1))]:-}"
    IF="${IF##*|}"

    if [[ -n "$IF" ]]; then
      print_ok "Selected interface: $IF"
      break
    fi

    print_warn "Invalid option."
  done
}

get_gateway() {
  ipconfig getpacket "$IF" 2>/dev/null | awk -F"[{}]" '/router/ {print $2; exit}'
}

get_network() {
  ipconfig getifaddr "$IF" | awk -F. '{print $1"."$2"."$3".0/24"}'
}

colorize_scan_output() {
  awk -v green="$GREEN" -v yellow="$YELLOW" -v red="$RED" -v nc="$NC" '
    /Nmap done|Host is up|open|ports/ { print green $0 nc; next }
    /80\/tcp|443\/tcp|8080\/tcp|8443\/tcp|http|https|VNC|RDP|SSH/ { print yellow $0 nc; next }
    /DHCP Message Type|DHCPOFFER|rogue|unexpected|WARNING|CRITICAL/ { print red $0 nc; next }
    { print }
  '
}

run_scan() {
  local title="$1"
  local cmd="$2"
  local scan_output_file="/tmp/lss-scan-output"

  echo | tee -a "$LOGFILE"
  echo "$title" | tee -a "$LOGFILE"
  echo "----------------" | tee -a "$LOGFILE"

  echo "----------------------------------------" | tee -a "$LOGFILE"
  echo "Running scan..." | tee -a "$LOGFILE"
  echo "----------------------------------------" | tee -a "$LOGFILE"

  eval "$cmd" > "$scan_output_file" 2>&1 &
  local scan_pid=$!

  spinner $scan_pid
  wait $scan_pid || true

  cat "$scan_output_file" | tee -a "$LOGFILE" | colorize_scan_output

  echo | tee -a "$LOGFILE"
  echo "----------------------------------------" | tee -a "$LOGFILE"
  echo "Scan complete" | tee -a "$LOGFILE"
  echo "----------------------------------------" | tee -a "$LOGFILE"
}

ensure_discovery_cache() {
  local net
  net="$(get_network)"

  if [[ ! -f "$DISCOVERY_CACHE" ]]; then
    echo "Running network discovery..." | tee -a "$LOGFILE"
    run_scan "Discovering devices on $net (cached)" "sudo nmap -sn $net | tee $DISCOVERY_CACHE"
  else
    echo "Using cached discovery results" | tee -a "$LOGFILE"
  fi
}

run_dhcp_discover_scan() {
  if [[ "$DHCP_SCAN_RAN" -eq 1 ]]; then
    print_info "Using cached DHCP scan results" | tee -a "$LOGFILE"
    return 0
  fi

  echo "---" | tee -a "$LOGFILE"
  print_info "## Running scan..." | tee -a "$LOGFILE"
  print_info "Running DHCP detection..." | tee -a "$LOGFILE"

  DHCP_SCAN_OUTPUT="$(sudo nmap --script broadcast-dhcp-discover -e "$IF" 2>/dev/null || true)"
  DHCP_SCAN_RAN=1

  echo "$DHCP_SCAN_OUTPUT" | tee -a "$LOGFILE" | colorize_scan_output

  echo "---" | tee -a "$LOGFILE"
  print_info "## Scan complete" | tee -a "$LOGFILE"
}

dhcp_server_count() {
  echo "$DHCP_SCAN_OUTPUT" | grep -c "Server Identifier" || true
}

interface_info() {
  CURRENT_GATEWAY="$(get_gateway)"
  {
    echo
    echo "Interface: $IF"
    echo "IP: $(ipconfig getifaddr "$IF" 2>/dev/null || echo "N/A")"
    echo "Subnet: $(ipconfig getoption "$IF" subnet_mask 2>/dev/null || echo "N/A")"
    echo "Gateway: ${CURRENT_GATEWAY:-N/A}"
    echo "DNS: $(ipconfig getpacket "$IF" 2>/dev/null | awk -F"[{}]" '/domain_name_server/ {print $2; exit}')"
    echo "DHCP: $(ipconfig getoption "$IF" server_identifier 2>/dev/null || echo "N/A")"
    echo
  } | tee -a "$LOGFILE"
}

discover_devices() {
  ensure_discovery_cache

  echo
  print_info "Detected devices (IP + Vendor):"
  awk '
    /^Nmap scan report for / {
      ip=$NF
      vendor="Unknown"
      getline
      while ($0 !~ /^Nmap scan report for / && $0 !~ /^Nmap done/ && $0 !~ /^$/) {
        if ($0 ~ /MAC Address:/) {
          split($0, a, "(")
          vendor=a[2]
          gsub(/\)/, "", vendor)
          break
        }
        if (getline <= 0) break
      }
      printf "%-16s %s\n", ip, vendor
    }
  ' "$DISCOVERY_CACHE" | tee -a "$LOGFILE"
}

gateway_ports() {
  local gw
  gw="$(get_gateway)"
  run_scan "Gateway open port scan ($gw)" "sudo nmap --stats-every 5s -Pn -T4 --open $gw"
}

gateway_fingerprint() {
  local gw
  gw="$(get_gateway)"
  run_scan "Gateway fingerprint ($gw)" "sudo nmap --stats-every 5s -Pn -A -T4 --top-ports 100 $gw"
}

rogue_dhcp() {
  run_dhcp_discover_scan
  print_alert "Review DHCP offers above. Unexpected DHCP responders should be treated as rogue."
}

network_map() {
  ensure_discovery_cache
  run_scan "Network map (cached discovery results)" "cat $DISCOVERY_CACHE"
}

find_web_interfaces() {
  local net
  net="$(get_network)"
  run_scan "Scanning for web admin interfaces on $net" "sudo nmap --stats-every 5s -p 80,443,8080,8443 --open $net"
  print_warn "Potential management interfaces detected above (yellow lines)."
}

find_remote_access() {
  local net
  net="$(get_network)"
  run_scan "Scanning for remote access services on $net" "sudo nmap --stats-every 5s -p 22,3389,5900 --open $net"
}

speed_test() {
  run_scan "Running internet speed test" "speedtest-cli"
}

build_topology_summary() {
  local total apple printers routers unknown
  ensure_discovery_cache

  total="$(grep -c '^Nmap scan report for ' "$DISCOVERY_CACHE" 2>/dev/null || true)"
  apple="$(grep -Ei 'MAC Address: .*\(.*Apple' "$DISCOVERY_CACHE" 2>/dev/null | wc -l | tr -d ' ' || true)"
  printers="$(grep -Ei 'MAC Address: .*\(.*(HP|Brother|Canon|Epson|Xerox|Lexmark)' "$DISCOVERY_CACHE" 2>/dev/null | wc -l | tr -d ' ' || true)"
  routers="$(grep -Ei 'MAC Address: .*\(.*(Ubiquiti|Cisco|MikroTik|Netgear|TP-Link|ASUS|Juniper)' "$DISCOVERY_CACHE" 2>/dev/null | wc -l | tr -d ' ' || true)"
  unknown="$(grep -Ei 'MAC Address: .*\(Unknown\)' "$DISCOVERY_CACHE" 2>/dev/null | wc -l | tr -d ' ' || true)"

  echo | tee -a "$LOGFILE"
  echo "Network Summary" | tee -a "$LOGFILE"
  echo "----------------" | tee -a "$LOGFILE"
  echo "Gateway: $(get_gateway)" | tee -a "$LOGFILE"
  echo "Devices detected: ${total:-0}" | tee -a "$LOGFILE"
  echo | tee -a "$LOGFILE"
  echo "Breakdown:" | tee -a "$LOGFILE"
  echo "Apple devices: ${apple:-0}" | tee -a "$LOGFILE"
  echo "Printers: ${printers:-0}" | tee -a "$LOGFILE"
  echo "Routers: ${routers:-0}" | tee -a "$LOGFILE"
  echo "Unknown devices: ${unknown:-0}" | tee -a "$LOGFILE"

}

network_health_summary() {
  local net gw discovery_file mgmt_file remote_file
  local gateway_reachable internet_reachable devices dhcp_count mgmt_count remote_count unknown_devices
  net="$(get_network)"
  gw="$(get_gateway)"
  ensure_discovery_cache
  discovery_file="$DISCOVERY_CACHE"
  mgmt_file="$(mktemp /tmp/lss-health-mgmt.XXXXXX)"
  remote_file="$(mktemp /tmp/lss-health-remote.XXXXXX)"

  run_dhcp_discover_scan

  echo "---" | tee -a "$LOGFILE"
  print_info "## Running scan..." | tee -a "$LOGFILE"
  print_info "Running management interface scan..." | tee -a "$LOGFILE"
  print_info "Scanning network $net" | tee -a "$LOGFILE"
  sudo nmap --stats-every 5s -p 80,443,8080,8443 --open "$net" > "$mgmt_file" 2>/dev/null || true
  echo "---" | tee -a "$LOGFILE"
  print_info "## Scan complete" | tee -a "$LOGFILE"

  echo "---" | tee -a "$LOGFILE"
  print_info "## Running scan..." | tee -a "$LOGFILE"
  print_info "Running remote access scan..." | tee -a "$LOGFILE"
  print_info "Scanning network $net" | tee -a "$LOGFILE"
  sudo nmap --stats-every 5s -p 22,3389,5900 --open "$net" > "$remote_file" 2>/dev/null || true
  echo "---" | tee -a "$LOGFILE"
  print_info "## Scan complete" | tee -a "$LOGFILE"

  if ping -c1 -t1 "$gw" >/dev/null 2>&1; then
    gateway_reachable="YES"
  else
    gateway_reachable="NO"
  fi

  if ping -c1 -t1 8.8.8.8 >/dev/null 2>&1; then
    internet_reachable="YES"
  else
    internet_reachable="NO"
  fi

  devices="$(grep -c '^Nmap scan report for ' "$discovery_file" 2>/dev/null || true)"
  dhcp_count="$(dhcp_server_count)"
  mgmt_count="$(grep -c '^Nmap scan report for ' "$mgmt_file" 2>/dev/null || true)"
  remote_count="$(grep -c '^Nmap scan report for ' "$remote_file" 2>/dev/null || true)"
  unknown_devices="$(grep -Ei 'MAC Address: .*(Unknown)' "$discovery_file" 2>/dev/null | wc -l | tr -d ' ')"

  echo | tee -a "$LOGFILE"
  echo "## Network Health Summary" | tee -a "$LOGFILE"
  echo | tee -a "$LOGFILE"
  echo "Interface: $IF" | tee -a "$LOGFILE"
  echo "Gateway: ${gw:-N/A}" | tee -a "$LOGFILE"
  echo | tee -a "$LOGFILE"
  echo "Gateway reachable: $gateway_reachable" | tee -a "$LOGFILE"
  echo "Internet reachable: $internet_reachable" | tee -a "$LOGFILE"
  echo | tee -a "$LOGFILE"
  echo "Devices discovered: ${devices:-0}" | tee -a "$LOGFILE"
  echo "DHCP servers detected: ${dhcp_count:-0}" | tee -a "$LOGFILE"
  echo | tee -a "$LOGFILE"
  echo "Management interfaces found: ${mgmt_count:-0}" | tee -a "$LOGFILE"
  echo "Remote access services: ${remote_count:-0}" | tee -a "$LOGFILE"

  if [[ "$dhcp_count" -gt 1 || "$remote_count" -gt 0 || "$unknown_devices" -gt 0 ]]; then
    echo | tee -a "$LOGFILE"
    print_alert "Warnings:" | tee -a "$LOGFILE"
  fi

  if [[ "$dhcp_count" -gt 1 ]]; then
    print_alert "WARNING: Multiple DHCP servers detected" | tee -a "$LOGFILE"
  fi
  if [[ "$remote_count" -gt 0 ]]; then
    print_alert "WARNING: Remote access services exposed" | tee -a "$LOGFILE"
  fi
  if [[ "$unknown_devices" -gt 0 ]]; then
    print_alert "WARNING: Unknown devices detected" | tee -a "$LOGFILE"
  fi

  rm -f "$mgmt_file" "$remote_file"
}

refresh_discovery_scan() {
  rm -f "$DISCOVERY_CACHE"
  DHCP_SCAN_RAN=0
  DHCP_SCAN_OUTPUT=""
  ensure_discovery_cache
}

export_report() {
  local date_stamp generated gateway dest
  date_stamp="$(date '+%Y-%m-%d_%H-%M-%S')"
  generated="$(date '+%Y-%m-%d %H:%M:%S')"
  gateway="$(get_gateway)"
  dest="$HOME/Desktop/LSS-NetInfo-Export-$date_stamp.txt"

  {
    echo "LSS NetInfo Report"
    echo "Generated: $generated"
    echo "Interface: $IF"
    echo "-----------------------------------"
    if sed -r '' </dev/null >/dev/null 2>&1; then
      cat "$LOGFILE" | sed -r 's/\x1B\[[0-9;]*[mK]//g'
    else
      cat "$LOGFILE" | sed -E 's/\x1B\[[0-9;]*[mK]//g'
    fi | sed '/^## Running scan\.\.\.$/d; /^## Scan complete$/d; /^Running .*\.\.\.$/d; /^Scanning network /d; /^Using cached DHCP scan results$/d; /^---$/d; /^----------------------------------------$/d'
  } > "$dest"

  print_ok "Export saved to: $dest"
}

show_menu() {
  echo
  echo "================================="
  echo "    LSS macOS Network Tools"
  echo "================================="
  echo "1) Interface Network Info"
  echo "2) Discover Devices (Vendor Detection)"
  echo "3) Gateway Port Scan"
  echo "4) Gateway Fingerprint"
  echo "5) Rogue DHCP Detection"
  echo "6) Network Map"
  echo "7) Find Web Admin Interfaces"
  echo "8) Find Remote Access Services"
  echo "9) Internet Speed Test"
  echo "10) Network Topology Summary"
  echo "11) Network Health Summary"
  echo "12) Refresh discovery scan"
  echo
  echo "0) Exit"
  echo
}

main() {
  run_dependency_check
  check_for_updates
  sudo -v
  select_interface

  while true; do
    local opt
    show_menu
    read -r -p "Select option: " opt

    case "$opt" in
      1) interface_info ;;
      2) discover_devices ;;
      3) gateway_ports ;;
      4) gateway_fingerprint ;;
      5) rogue_dhcp ;;
      6) network_map ;;
      7) find_web_interfaces ;;
      8) find_remote_access ;;
      9) speed_test ;;
      10) build_topology_summary ;;
      11) network_health_summary ;;
      12) refresh_discovery_scan ;;
      0)
        echo
        read -r -p "Export session report to Desktop? (y/n) " exp
        if [[ "$exp" == "y" || "$exp" == "Y" ]]; then
          export_report
        fi
        exit 0
        ;;
      *) print_warn "Invalid option." ;;
    esac
  done
}

main "$@"
